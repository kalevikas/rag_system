# Streamlit secrets template — copy to .streamlit/secrets.toml and fill in values
# On Streamlit Cloud, set these in the "Secrets" section of your app settings.
# NEVER commit secrets.toml to Git.

OPENAI_API_KEY   = "sk-..."        # your OpenAI API key

# ── Qdrant Cloud (required for cloud deployment) ──────────────────────────────
# Sign up free at https://cloud.qdrant.io — 1 GB free tier
QDRANT_URL       = "https://your-cluster-id.us-east-1-0.aws.cloud.qdrant.io"
QDRANT_API_KEY   = "your-qdrant-api-key"
